{
  "name": "laundryapp-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "check:mobile": "node --max-old-space-size=4096 apps/mobile/node_modules/typescript/bin/tsc --project apps/mobile/tsconfig.json --noEmit",
    "check:functions": "npm --prefix apps/functions run build",
    "check:all": "npm run check:mobile && npm run check:functions",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:ios": "npm --prefix apps/mobile run ios",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck",
    "mobile:eas:whoami": "cd apps/mobile && npx eas-cli whoami",
    "mobile:eas:login": "cd apps/mobile && npx eas-cli login",
    "mobile:eas:init": "cd apps/mobile && npx eas-cli init",
    "mobile:readiness:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile-readiness-check.ps1 -Environment staging",
    "mobile:readiness:production": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile-readiness-check.ps1 -Environment production",
    "mobile:build:android:staging": "npm run mobile:readiness:staging && cd apps/mobile && npx eas-cli build --profile preview --platform android",
    "mobile:build:ios:staging": "npm run mobile:readiness:staging && cd apps/mobile && npx eas-cli build --profile preview --platform ios",
    "mobile:build:android:preview": "cd apps/mobile && npx eas-cli build --profile preview --platform android",
    "mobile:build:ios:preview": "cd apps/mobile && npx eas-cli build --profile preview --platform ios",
    "check:emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/check-firebase-emulator.ps1",
    "test:firestore:rules": "node tests/firestore-rules.test.mjs",
    "test:emulator": "npm run check:emulator && npx firebase-tools emulators:exec --only firestore \"npm run test:firestore:rules\"",
    "test:routes:refresh": "powershell -ExecutionPolicy Bypass -File ./scripts/check-direct-route-refresh.ps1",
    "test:regression": "npm run check:functions && npm run test:emulator",
    "test:phase5": "npm run test:emulator && npm run test:routes:refresh",
    "emulators:start": "npx firebase-tools emulators:start --only firestore",
    "firebase:login": "powershell -ExecutionPolicy Bypass -Command \"$env:NODE_OPTIONS='--use-system-ca'; npx firebase-tools login\"",
    "firebase:projects": "powershell -ExecutionPolicy Bypass -Command \"$env:NODE_OPTIONS='--use-system-ca'; npx firebase-tools projects:list\"",
    "env:demo:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check-staging-env.ps1 -Environment demo",
    "env:staging:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check-staging-env.ps1 -Environment staging",
    "env:production:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check-staging-env.ps1 -Environment production",
    "preview:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/staging-web-preview.ps1",
    "firebase:use:demo": "npx firebase-tools use demo",
    "firebase:use:staging": "npx firebase-tools use staging",
    "firebase:use:production": "npx firebase-tools use production",
    "deploy:demo:firestore": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-deploy.ps1 -Environment demo -Target firestore -SkipFunctionsBuild",
    "deploy:demo:functions": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-deploy.ps1 -Environment demo -Target functions",
    "deploy:demo": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-deploy.ps1 -Environment demo",
    "deploy:staging:firestore": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-deploy.ps1 -Environment staging -Target firestore -SkipFunctionsBuild",
    "deploy:staging:functions": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-deploy.ps1 -Environment staging -Target functions",
    "deploy:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-deploy.ps1 -Environment staging",
    "deploy:production:firestore": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-deploy.ps1 -Environment production -Target firestore -SkipFunctionsBuild",
    "deploy:production:functions": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-deploy.ps1 -Environment production -Target functions",
    "deploy:production": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-deploy.ps1 -Environment production",
    "backup:staging:plan": "powershell -ExecutionPolicy Bypass -File ./scripts/firestore-backup-export.ps1 -Environment staging",
    "backup:production:plan": "powershell -ExecutionPolicy Bypass -File ./scripts/firestore-backup-export.ps1 -Environment production",
    "backup:staging:run": "powershell -ExecutionPolicy Bypass -File ./scripts/firestore-backup-export.ps1 -Environment staging -RunExport",
    "backup:production:run": "powershell -ExecutionPolicy Bypass -File ./scripts/firestore-backup-export.ps1 -Environment production -RunExport -AllowProduction",
    "monitoring:staging:plan": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-monitoring-review.ps1 -Environment staging",
    "monitoring:production:plan": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-monitoring-review.ps1 -Environment production",
    "monitoring:staging:logs": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-monitoring-review.ps1 -Environment staging -RunLogs",
    "monitoring:production:logs": "powershell -ExecutionPolicy Bypass -File ./scripts/firebase-monitoring-review.ps1 -Environment production -RunLogs -AllowProduction",
    "admin-recovery:staging:plan": "powershell -ExecutionPolicy Bypass -File ./scripts/admin-recovery-plan.ps1 -Environment staging",
    "admin-recovery:production:plan": "powershell -ExecutionPolicy Bypass -File ./scripts/admin-recovery-plan.ps1 -Environment production",
    "qa:staging:roles": "node scripts/staging-role-qa.mjs",
    "qa:staging:rewards": "node scripts/staging-rewards-qa.mjs",
    "qa:staging:notifications": "node scripts/staging-notifications-qa.mjs",
    "qa:staging:stripe-paymentintent": "node scripts/staging-stripe-paymentintent-qa.mjs",
    "phase6:staging:check": "powershell -ExecutionPolicy Bypass -File ./scripts/production-hardening-check.ps1 -Environment staging",
    "phase6:production:check": "powershell -ExecutionPolicy Bypass -File ./scripts/production-hardening-check.ps1 -Environment production",
    "phase6:all:check": "powershell -ExecutionPolicy Bypass -File ./scripts/production-hardening-check.ps1 -Environment all",
    "phase8:staging:check": "powershell -ExecutionPolicy Bypass -File ./scripts/phase8-production-readiness.ps1 -Environment staging",
    "phase8:production:check": "powershell -ExecutionPolicy Bypass -File ./scripts/phase8-production-readiness.ps1 -Environment production",
    "phase8:all:check": "powershell -ExecutionPolicy Bypass -File ./scripts/phase8-production-readiness.ps1 -Environment all"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.15.0"
  }
}
