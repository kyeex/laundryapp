rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function currentUser() {
      return userDoc(request.auth.uid);
    }

    function hasRole(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUser().data.role == role
        && currentUser().data.active == true;
    }

    function isOwner() {
      return hasRole("owner");
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isCustomer() {
      return hasRole("customer");
    }

    function isDriver() {
      return hasRole("driver");
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validUserRole(role) {
      return role in ["customer", "owner", "driver", "admin"];
    }

    function validAdminManagedUser() {
      return validUserRole(request.resource.data.role)
        && request.resource.data.active is bool
        && request.resource.data.email is string
        && request.resource.data.displayName is string;
    }

    function isActiveDriverUser(user) {
      return user.role == "driver" && user.active == true;
    }

    function isOwnOrder(order) {
      return signedIn() && order.customerId == request.auth.uid;
    }

    function isAssignedDriver(order) {
      return signedIn()
        && (
          order.assignedPickupDriverId == request.auth.uid
          || order.assignedDeliveryDriverId == request.auth.uid
        );
    }

    function validCustomerOrderCreate() {
      return isCustomer()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == "requested"
        && request.resource.data.paymentStatus == "unpaid"
        && request.resource.data.finalPrice == null;
    }

    function driverCanUpdateAssignedOrderStatus() {
      return isDriver()
        && isAssignedDriver(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "updatedAt"])
        && request.resource.data.status in [
          "pickup_assigned",
          "picked_up",
          "failed_pickup",
          "delivery_assigned",
          "delivered",
          "failed_delivery"
        ];
    }

    function driverCanSubmitRoute() {
      return isDriver()
        && resource.data.driverId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "updatedAt"])
        && request.resource.data.status == "completed";
    }

    function canCreateOrderEvent(orderId) {
      return signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && exists(/databases/$(database)/documents/orders/$(orderId))
        && (
          isOwner()
          || get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid
          || get(/databases/$(database)/documents/orders/$(orderId)).data.assignedPickupDriverId == request.auth.uid
          || get(/databases/$(database)/documents/orders/$(orderId)).data.assignedDeliveryDriverId == request.auth.uid
        );
    }

    function validAuditResourceType() {
      return request.resource.data.resourceType in [
        "order",
        "batch",
        "catalog",
        "configuration",
        "user",
        "payment",
        "rewards"
      ];
    }

    function isOwnAuditLog() {
      return signedIn()
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.actorRole == currentUser().data.role
        && validAuditResourceType();
    }

    function canCreateDriverAuditLog() {
      return isDriver()
        && isOwnAuditLog()
        && (
          (
            request.resource.data.resourceType == "order"
            && request.resource.data.action == "order.driver_stop_updated"
            && exists(/databases/$(database)/documents/orders/$(request.resource.data.resourceId))
            && isAssignedDriver(
              get(/databases/$(database)/documents/orders/$(request.resource.data.resourceId)).data
            )
          )
          || (
            request.resource.data.resourceType == "batch"
            && request.resource.data.action == "batch.route_submitted"
            && exists(/databases/$(database)/documents/batches/$(request.resource.data.resourceId))
            && get(/databases/$(database)/documents/batches/$(request.resource.data.resourceId)).data.driverId == request.auth.uid
          )
        );
    }

    match /users/{userId} {
      allow read: if ownsUserDoc(userId)
        || isAdmin()
        || (isOwner() && isActiveDriverUser(resource.data));
      allow create: if (
          ownsUserDoc(userId)
          && request.resource.data.role == "customer"
          && request.resource.data.active == true
        )
        || (isAdmin() && validAdminManagedUser());
      allow update: if (
          ownsUserDoc(userId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              "displayName",
              "email",
              "phone",
              "expoPushTokens",
              "updatedAt"
            ])
          && request.resource.data.role == resource.data.role
          && request.resource.data.active == resource.data.active
        )
        || (isAdmin() && validAdminManagedUser());
      allow delete: if false;
    }

    match /customerProfiles/{userId} {
      allow read, create, update: if ownsUserDoc(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /driverProfiles/{userId} {
      allow read: if ownsUserDoc(userId) || isOwner() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /addresses/{addressId} {
      allow get: if isAdmin()
        || (signedIn() && addressId == request.auth.uid + "-default")
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if (isCustomer()
          && request.resource.data.userId == request.auth.uid)
        || isAdmin();
      allow update, delete: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
        );
    }

    match /customerPreferences/{userId} {
      allow read, create, update: if ownsUserDoc(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /loyaltyRewards/{userId} {
      allow read: if ownsUserDoc(userId) || isOwner() || isAdmin();
      allow create, update, delete: if isOwner() || isAdmin();
    }

    match /loyaltyRewardEvents/{eventId} {
      allow read: if isOwner()
        || isAdmin()
        || (isCustomer() && resource.data.customerId == request.auth.uid);
      allow create: if (isOwner() || isAdmin())
        && request.resource.data.customerId is string
        && request.resource.data.points is number
        && request.resource.data.type in [
          "earned",
          "redeemed",
          "adjusted",
          "signup_bonus",
          "expired"
        ];
      allow update, delete: if false;
    }

    match /recurringOrders/{recurringOrderId} {
      allow read: if isOwner()
        || isAdmin()
        || (isCustomer() && resource.data.customerId == request.auth.uid);
      allow create: if isCustomer()
        && request.resource.data.customerId == request.auth.uid;
      allow update: if isOwner()
        || isAdmin()
        || (
          isCustomer()
          && resource.data.customerId == request.auth.uid
          && request.resource.data.customerId == request.auth.uid
        );
      allow delete: if isOwner()
        || isAdmin()
        || (isCustomer() && resource.data.customerId == request.auth.uid);
    }

    match /orders/{orderId} {
      allow read: if isOwner()
        || isOwnOrder(resource.data)
        || isAssignedDriver(resource.data);
      allow create: if validCustomerOrderCreate();
      allow update: if isOwner()
        || driverCanUpdateAssignedOrderStatus();
      allow delete: if isOwner();
    }

    match /auditLogs/{auditLogId} {
      allow read: if isOwner() || isAdmin();
      allow create: if ((isOwner() || isAdmin()) && isOwnAuditLog())
        || canCreateDriverAuditLog();
      allow update, delete: if false;
    }

    match /batches/{batchId} {
      allow read: if isOwner()
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create, update, delete: if isOwner()
        || driverCanSubmitRoute();
    }

    match /orderEvents/{eventId} {
      allow read: if isOwner()
        || (
          signedIn()
          && exists(/databases/$(database)/documents/orders/$(resource.data.orderId))
          && (
            get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.customerId == request.auth.uid
            || get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.assignedPickupDriverId == request.auth.uid
            || get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.assignedDeliveryDriverId == request.auth.uid
          )
        );
      allow create: if canCreateOrderEvent(request.resource.data.orderId);
      allow update, delete: if false;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /addOns/{addOnId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /comforterSizeAddOns/{addOnId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /dryCleaningItems/{itemId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /pickupWindows/{pickupWindowId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /payments/{paymentId} {
      allow read: if isOwner()
        || (signedIn() && resource.data.customerId == request.auth.uid);
      allow write: if false;
    }
  }
}
